# ═══════════════════════════════════════════════════════════
# RANNABANNA — ENTERPRISE BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Core Express server port (default 3001)
PORT=3001

# Operational Environment mode (development / production)
NODE_ENV=development

# Google Gemini API Key for dynamic custom recipe generation
# Acquire a key from Google AI Studio (https://aistudio.google.com/)
# If empty/missing, the backend automatically triggers local high-precision expert system
GEMINI_API_KEY=

# In-Memory Cache configuration
# TTL in milliseconds (default 600000 = 10 minutes)
CACHE_TTL_MS=600000

# Rate Limiter settings
# Max requests permitted inside a 15-minute sliding window (default 100)
RATE_LIMIT_MAX=100
